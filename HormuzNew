                    </div>
                    
                    <div className="mt-8 text-center">
                        {!allCorrect && <button onClick={checkAnswers} disabled={Object.keys(selections).length < steps.length} className="px-10 py-3 bg-secondary text-white text-xl font-medium rounded-xl shadow disabled:opacity-50 hover:bg-blue-800 transition">בדוק תרשים</button>}
                        {allCorrect && <div className="text-2xl font-medium text-success fade-in px-10 py-3 bg-pink-100 rounded-xl inline-block border-2 border-success shadow-md">מעולה! הרכבתם את התרשים במדויק!</div>}
                    </div>
                </div>
            );
        };

        const ScreenFlashGame = ({ nikkudLevel }) => {
            const [gameState, setGameState] = useState('start'); 
            const [score, setScore] = useState(0);
            const [timeLeft, setTimeLeft] = useState(120);
            const [displayTime, setDisplayTime] = useState(2); 
            const [gameDuration, setGameDuration] = useState(120); 
            const [currentWord, setCurrentWord] = useState(null);
            const [feedback, setFeedback] = useState(null);
            const [clickedWrongOpt, setClickedWrongOpt] = useState(null);
            const [unplayedWords, setUnplayedWords] = useState([...CONTENT.flashData]);

            useEffect(() => {
                let timer;
                if (gameState === 'word' || gameState === 'guess') {
                    timer = setInterval(() => {
                        setTimeLeft(prev => {
                            if (prev <= 1) { setGameState('end'); return 0; }
                            return prev - 1;
                        });
                    }, 1000);
                }
                return () => clearInterval(timer);
            }, [gameState]);

            const nextWord = (currentPool = unplayedWords) => {
                let pool = currentPool;
                if (pool.length === 0) {
                    pool = [...CONTENT.flashData];
                    setUnplayedWords(pool);
                }
                const randomItem = pool[Math.floor(Math.random() * pool.length)];
                const shuffledOptions = [...randomItem.options].sort(() => Math.random() - 0.5);
                setCurrentWord({ ...randomItem, shuffledOptions });
                setGameState('word');
                setFeedback(null);
                setClickedWrongOpt(null);
                setTimeout(() => {
                    setGameState(prev => prev === 'word' ? 'guess' : prev);
                }, displayTime * 1000);
            };

            const startGame = () => {
                setScore(0);
                setTimeLeft(gameDuration);
                setUnplayedWords([...CONTENT.flashData]);
                nextWord([...CONTENT.flashData]);
            };

            const handleGuess = (opt) => {
                if (opt === currentWord.word) {
                    playSuccess();
                    setScore(s => s + 5);
                    setFeedback('correct');
                    setClickedWrongOpt(null);
                    
                    const updatedPool = unplayedWords.filter(w => w.word !== currentWord.word);
                    setUnplayedWords(updatedPool);
                    
                    setTimeout(() => {
                        if (timeLeft > 0 && gameState !== 'end') nextWord(updatedPool);
                    }, 1000);
                } else {
                    playError();
                    setScore(s => Math.max(0, s - 5)); 
                    setFeedback('error');
                    setClickedWrongOpt(opt);
                    
                    setTimeout(() => {
                        if (timeLeft > 0 && gameState !== 'end') {
                            setGameState('word');
                            setFeedback(null);
                            setClickedWrongOpt(null);
                            setTimeout(() => {
                                setGameState(prev => prev === 'word' ? 'guess' : prev);
                            }, displayTime * 1000);
                        }
                    }, 1000);
                }
            };

            return (
                <div className="flex flex-col items-center justify-start min-h-[70vh] fade-in w-full max-w-3xl mx-auto pb-10">
                    <h2 className="text-3xl font-medium text-secondary mb-2 text-center">משחק זיהוי מהיר</h2>
                    <p className="text-center text-gray-700 mb-6 font-normal">מילה תופיע על המסך ותעלם במהירות. מצאו אותה בין האפשרויות! (+5 נק' להצלחה, -5 נק' לטעות)</p>
                    
                    <div className="flex justify-between items-center w-full mb-8 bg-white p-4 rounded-xl shadow border-2 border-accent">
                        <div className="text-2xl font-medium text-primary">ניקוד: <span dir="ltr">{score}</span></div>
                        <div className={`text-2xl font-medium font-mono ${timeLeft <= 10 ? 'text-error animate-pulse' : 'text-secondary'}`}>
                            <i className="fa-regular fa-clock"></i> {Math.floor(timeLeft / 60)}:{(timeLeft % 60).toString().padStart(2, '0')}
                        </div>
                    </div>

                    <div className="flex-1 flex flex-col items-center justify-center w-full min-h-[300px]">
                        {gameState === 'start' && (
                            <div className="flex flex-col items-center gap-6 w-full">
                                <div className="grid grid-cols-1 md:grid-cols-2 gap-4 w-full">
                                    <div className="flex flex-wrap justify-center gap-3 bg-blue-50 p-4 rounded-xl border border-accent">
                                        <span className="text-xl font-medium text-secondary w-full text-center mb-2">קבעו את זמן היעלמות המילה:</span>
                                        {[0.5, 1, 2, 3].map(sec => (
                                            <button key={sec} onClick={() => setDisplayTime(sec)} className={`px-4 py-2 rounded-lg font-medium border-2 transition-all ${displayTime === sec ? 'bg-primary text-white border-primary scale-105' : 'bg-white text-secondary border-accent hover:bg-blue-100'}`}>
                                                {sec === 0.5 ? 'חצי שנייה' : sec === 1 ? 'שנייה' : sec + ' שניות'}
                                            </button>
                                        ))}
                                    </div>
                                    <div className="flex flex-wrap justify-center gap-3 bg-blue-50 p-4 rounded-xl border border-accent">
                                        <span className="text-xl font-medium text-secondary w-full text-center mb-2">קבעו את אורך המשחק:</span>
                                        {[30, 60, 90, 120].map(sec => (
                                            <button key={`dur-${sec}`} onClick={() => setGameDuration(sec)} className={`px-4 py-2 rounded-lg font-medium border-2 transition-all ${gameDuration === sec ? 'bg-primary text-white border-primary scale-105' : 'bg-white text-secondary border-accent hover:bg-blue-100'}`}>
                                                {sec === 30 ? 'חצי דקה' : sec === 60 ? 'דקה' : sec === 90 ? 'דקה וחצי' : '2 דקות'}
                                            </button>
                                        ))}
                                    </div>
                                </div>
                                <button onClick={startGame} className="px-10 py-5 bg-success text-white text-3xl font-medium rounded-2xl shadow-lg hover:bg-pink-600 transition animate-glow">
                                    <i className="fa-solid fa-play mr-2"></i> התחל משחק ({gameDuration === 30 ? 'חצי דקה' : gameDuration === 60 ? 'דקה' : gameDuration === 90 ? 'דקה וחצי' : 'שתי דקות'})
                                </button>
                            </div>
                        )}
                        
                        {gameState === 'word' && currentWord && (
                            <div className="text-6xl md:text-8xl font-medium text-secondary animate-pulse fade-in">
                                {formatText(currentWord.word, nikkudLevel)}
                            </div>
                        )}

                        {gameState === 'guess' && currentWord && (
                            <div className="w-full flex flex-col items-center gap-6 fade-in">
                                <div className="text-3xl font-medium text-secondary mb-4">איזו מילה הופיעה?</div>
                                <div className="grid grid-cols-1 md:grid-cols-3 gap-4 w-full">
                                    {currentWord.shuffledOptions.map((opt, i) => (
                                        <button key={i} onClick={() => handleGuess(opt)} disabled={feedback !== null} 
                                            className={`py-6 px-4 text-3xl font-medium rounded-xl border-4 shadow-md transition-all ${
                                                feedback === 'correct' && opt === currentWord.word ? 'bg-pink-100 border-success text-success scale-105' :
                                                feedback === 'error' && opt === clickedWrongOpt ? 'bg-red-50 border-error text-error opacity-50 shake' :
                                                'bg-white border-accent text-secondary hover:bg-blue-50'
                                            }`}
                                        >
                                            {formatText(opt, nikkudLevel)}
                                        </button>
                                    ))}
                                </div>
                                {feedback === 'correct' && <div className="text-success text-4xl font-medium fade-in mt-4">+5 נקודות!</div>}
                                {feedback === 'error' && <div className="text-error text-4xl font-medium fade-in mt-4 shake">-5 נקודות. מנסים שוב!</div>}
                            </div>
                        )}

                        {gameState === 'end' && (
                            <div className="flex flex-col items-center gap-6 fade-in bg-blue-50 p-10 rounded-3xl border-4 border-secondary text-center shadow-xl">
                                <i className="fa-solid fa-trophy text-6xl text-yellow-500 mb-2 drop-shadow-md"></i>
                                <h3 className="text-4xl font-medium text-secondary">הזמן עבר!</h3>
                                <p className="text-3xl font-medium text-primary">הניקוד הסופי שלך: {score}</p>
                                <button onClick={startGame} className="mt-4 px-8 py-4 bg-secondary text-white text-xl font-medium rounded-xl shadow hover:bg-blue-800 transition">שחקו שוב</button>
                            </div>
                        )}
                    </div>
                </div>
            );
        };

        const ScreenSurvey = ({ onExport }) => {
            const [ratings, setRatings] = useState({ interest: null, difficulty: null, newThings: null });
            const [submitted, setSubmitted] = useState(false);

            return (
                <div className="flex flex-col items-center justify-center min-h-[70vh] fade-in w-full max-w-3xl mx-auto space-y-6 pb-10">
                    <h2 className="text-4xl md:text-5xl font-medium text-success mb-2 text-center">כל הכבוד, סיימתם את הלומדה!</h2>
                    {!submitted ? (
                        <div className="bg-white p-8 rounded-2xl shadow-xl border-4 border-secondary w-full mt-4">
                            <h3 className="text-2xl font-medium text-secondary mb-6 text-center">נשמח לשמוע איך היה השיעור:</h3>
                            <div className="space-y-6">
                                {['interest', 'difficulty', 'newThings'].map((cat, i) => (
                                    <div key={cat} className="flex flex-col md:flex-row md:items-center justify-between gap-4 bg-blue-50 p-4 rounded-xl border border-accent">
                                        <span className="text-xl font-medium text-secondary">{['עניין', 'קושי', 'דברים חדשים'][i]}</span>
                                        <div className="flex gap-6 justify-center" dir="ltr">
                                            <button onClick={() => setRatings(prev => ({ ...prev, [cat]: 'sad' }))} className={`text-4xl ${ratings[cat] === 'sad' ? 'text-error' : 'text-gray-400 opacity-50 hover:opacity-100'}`}><i className="fa-solid fa-face-frown"></i></button>
                                            <button onClick={() => setRatings(prev => ({ ...prev, [cat]: 'meh' }))} className={`text-4xl ${ratings[cat] === 'meh' ? 'text-yellow-500' : 'text-gray-400 opacity-50 hover:opacity-100'}`}><i className="fa-solid fa-face-meh"></i></button>
                                            <button onClick={() => setRatings(prev => ({ ...prev, [cat]: 'happy' }))} className={`text-4xl ${ratings[cat] === 'happy' ? 'text-success' : 'text-gray-400 opacity-50 hover:opacity-100'}`}><i className="fa-solid fa-face-smile"></i></button>
                                        </div>
                                    </div>
                                ))}
                            </div>
                            <div className="mt-8 flex flex-col md:flex-row justify-center gap-4">
                                <button onClick={() => { setSubmitted(true); triggerConfetti(); playSuccess(); }} disabled={!ratings.interest || !ratings.difficulty || !ratings.newThings} className="px-10 py-4 bg-primary text-white text-xl font-medium rounded-xl shadow-lg disabled:opacity-50 hover:bg-red-800">שליחת משוב וסיום</button>
                                <button onClick={onExport} className="px-6 py-4 bg-secondary text-white text-xl font-medium rounded-xl shadow-lg flex items-center justify-center gap-2 hover:bg-blue-800"><i className="fa-solid fa-envelope"></i> צפייה בתוצאות</button>
                            </div>
                        </div>
                    ) : (
                        <div className="flex flex-col items-center gap-6 w-full">
                            <div className="bg-pink-100 p-8 rounded-2xl shadow-lg border-2 border-success text-center mt-8 fade-in w-full"><h3 className="text-3xl font-medium text-success mb-4">תודה רבה!</h3></div>
                            <button onClick={onExport} className="px-8 py-4 bg-secondary text-white text-xl font-medium rounded-xl shadow-lg flex items-center gap-3 fade-in hover:bg-blue-800"><i className="fa-solid fa-envelope"></i> לחצו כאן לצפייה בתוצאות</button>
                        </div>
                    )}
                </div>
            );
        };

        const App = () => {
            const [currentScreen, setCurrentScreen] = useState(0);
            const [nikkudLevel, setNikkudLevel] = useState('full');
            const [isMuted, setIsMuted] = useState(true);
            const [isShowResults, setIsShowResults] = useState(false); 
            
            const [fluencyAttempts, setFluencyAttempts] = useState([]);
            const [openAnswers, setOpenAnswers] = useState(Array(CONTENT.openQuestions.length).fill(""));
            
            const [teacherEmail, setTeacherEmail] = useState("");
            const [copySuccess, setCopySuccess] = useState(false);

            const audioCtxRef = useRef(null); const noiseNodeRef = useRef(null);

            const initNoise = () => {
                try {
                    if (!audioCtxRef.current) audioCtxRef.current = new (window.AudioContext || window.webkitAudioContext)();
                    if (!noiseNodeRef.current) {
                        const bufferSize = audioCtxRef.current.sampleRate * 2; const buffer = audioCtxRef.current.createBuffer(1, bufferSize, audioCtxRef.current.sampleRate);
                        const data = buffer.getChannelData(0); for (let i = 0; i < bufferSize; i++) data[i] = Math.random() * 2 - 1; 
                        const noise = audioCtxRef.current.createBufferSource(); noise.buffer = buffer; noise.loop = true;
                        const gainNode = audioCtxRef.current.createGain(); gainNode.gain.value = 0.03; 
                        noise.connect(gainNode); gainNode.connect(audioCtxRef.current.destination); noise.start(); noiseNodeRef.current = { source: noise, gain: gainNode };
                    }
                } catch(e) {}
            };

            useEffect(() => {
                if (audioCtxRef.current) { if (isMuted) { if (audioCtxRef.current.state === 'running') audioCtxRef.current.suspend(); } else { if (audioCtxRef.current.state === 'suspended') audioCtxRef.current.resume(); } }
            }, [isMuted, currentScreen]);

            const generateResultsText = () => {
                let text = `סיכום תוצאות אישי - ${formatText(CONTENT.title, 'none')}\n\n`;
                text += `--- שטף קריאה (WCPM) ---\n`;
                if (fluencyAttempts.length > 0) fluencyAttempts.forEach((a, i) => text += `ניסיון ${i + 1}: ${a.wcpm} מילים בדקה\n`);
                else text += `לא בוצע תרגול שטף קריאה.\n`;
                text += `\n--- שאלות פתוחות ---\n`;
                CONTENT.openQuestions.forEach((q, i) => { text += `שאלה ${i + 1}: ${formatText(q, 'none')}\nתשובה: ${openAnswers[i] ? openAnswers[i] : 'לא ניתנה תשובה.'}\n\n`; });
                return text;
            };

            const handleCopyText = () => {
                const fullText = `תוצאות לומדה: ${formatText(CONTENT.title, 'none')}\n\n` + generateResultsText();
                const textArea = document.createElement("textarea"); textArea.value = fullText; document.body.appendChild(textArea); textArea.select();
                try { document.execCommand('copy'); setCopySuccess(true); setTimeout(() => setCopySuccess(false), 3000); } catch (err) {} document.body.removeChild(textArea);
            };

            const screens = [
                <ScreenHome key="home" onNext={() => { if (!isMuted) { initNoise(); if (audioCtxRef.current && audioCtxRef.current.state === 'suspended') audioCtxRef.current.resume(); } setCurrentScreen(1); }} nikkudLevel={nikkudLevel} />,
                <ScreenVocab key="vocab" nikkudLevel={nikkudLevel} />,
                <ScreenAuditory key="aud" nikkudLevel={nikkudLevel} />,
                <ScreenFluency key="fluency" nikkudLevel={nikkudLevel} attempts={fluencyAttempts} setAttempts={setFluencyAttempts} />,
                ...CONTENT.paragraphs.map((p, i) => <ScreenSingleParagraphStudy key={'para'+i} paraIdx={i} nikkudLevel={nikkudLevel} />),
                <ScreenOpenQuestions key="open" nikkudLevel={nikkudLevel} answers={openAnswers} setAnswers={setOpenAnswers} />,
                <ScreenLinguistic key="ling" nikkudLevel={nikkudLevel} />,
                <ScreenAnalogies key="analogy" nikkudLevel={nikkudLevel} />,
                <ScreenComparison key="comp" nikkudLevel={nikkudLevel} />,
                <ScreenFlowchart key="flow" nikkudLevel={nikkudLevel} />,
                <ScreenFlashGame key="game" nikkudLevel={nikkudLevel} />,
                <ScreenSurvey key="survey" onExport={() => setIsShowResults(true)} />
            ];

            const screenTitles = ["בית", "אוצר מילים", "שמיעתי", "שטף קריאה", ...CONTENT.paragraphs.map(p => `פסקה ${p.id}`), "שאלות פתוחות", "עבודה לשונית", "אנלוגיות", "טבלת השוואה", "תרשים זרימה", "זיהוי מהיר", "סיכום וסקר"];

            if (isShowResults) {
                return (
                    <div className="p-4 md:p-8 bg-bglight text-black min-h-screen" dir="rtl">
                        <div className="flex flex-col md:flex-row justify-between items-center mb-8 bg-white p-4 rounded-xl border-2 border-accent shadow-sm gap-4">
                            <div><h2 className="text-2xl font-medium text-secondary mb-1">סיכום תוצאות אישי</h2></div>
                            <button onClick={() => setIsShowResults(false)} className="px-6 py-3 bg-gray-200 text-gray-800 font-medium rounded-xl shadow hover:bg-gray-300 flex items-center gap-2"><i className="fa-solid fa-arrow-right"></i> חזור ללומדה</button>
                        </div>
                        <div className="max-w-4xl mx-auto">
                            <div className="bg-white p-6 rounded-2xl shadow-lg border-4 border-secondary mb-8 flex flex-col gap-4">
                                <h3 className="text-xl font-medium text-secondary">שליחת התוצאות</h3>
                                <input type="email" placeholder="כתובת המייל של המורה" className="p-3 border-2 border-accent rounded-lg outline-none w-full text-left bg-blue-50 font-normal" dir="ltr" value={teacherEmail} onChange={(e) => setTeacherEmail(e.target.value)} />
                                <div className="flex flex-col sm:flex-row gap-3 mt-2">
                                    <a href={`https://mail.google.com/mail/?view=cm&fs=1&to=${teacherEmail}&su=${encodeURIComponent('תוצאות לומדה: ' + formatText(CONTENT.title, 'none'))}&body=${encodeURIComponent(generateResultsText())}`} target="_blank" rel="noopener noreferrer" className="flex-1 px-4 py-4 bg-primary text-white font-medium rounded-xl text-center"><i className="fa-brands fa-google"></i> פתח ב-Gmail</a>
                                    <a href={`mailto:${teacherEmail}?subject=${encodeURIComponent('תוצאות לומדה: ' + formatText(CONTENT.title, 'none'))}&body=${encodeURIComponent(generateResultsText())}`} target="_blank" rel="noopener noreferrer" className="flex-1 px-4 py-4 bg-secondary text-white font-medium rounded-xl text-center"><i className="fa-solid fa-envelope"></i> אפליקציית מייל</a>
                                    <button onClick={handleCopyText} className="flex-1 px-4 py-4 bg-gray-700 text-white font-medium rounded-xl"><i className={`fa-solid ${copySuccess ? 'fa-check' : 'fa-copy'}`}></i> {copySuccess ? 'הועתק!' : 'העתק טקסט'}</button>
                                </div>
                            </div>
                            <h1 className="text-4xl font-medium text-primary border-b-4 border-accent pb-4 mb-8 text-center">סיכום אישי</h1>
                            <div className="mb-8 p-6 bg-white rounded-2xl border-2 border-accent shadow-sm">
                                <h2 className="text-2xl font-medium text-secondary mb-4">שטף קריאה (WCPM)</h2>
                                {fluencyAttempts.length > 0 ? fluencyAttempts.map((a, i) => <p key={i} className="text-xl mb-3 font-normal">ניסיון {i+1}: <span className="text-success font-medium">{a.wcpm} מילים בדקה</span></p>) : <p className="text-gray-600 font-normal">לא בוצע תרגול.</p>}
                            </div>
                            <div className="mb-8 p-6 bg-white rounded-2xl border-2 border-accent shadow-sm">
                                <h2 className="text-2xl font-medium text-secondary mb-6">שאלות פתוחות</h2>
                                {CONTENT.openQuestions.map((q, i) => (
                                    <div key={i} className="mb-6"><div className="font-medium text-xl mb-3 text-secondary">{i+1}. {formatText(q, 'none')}</div><div className="p-4 bg-blue-50 border-2 border-dashed border-accent rounded-xl min-h-[4rem] text-lg text-gray-800 font-normal">{openAnswers[i] || 'לא ניתנה תשובה.'}</div></div>
                                ))}
                            </div>
                        </div>
                    </div>
                );
            }

            return (
                <div className="flex flex-col min-h-screen bg-bglight relative print:hidden">
                    <div className="sticky top-0 z-50 w-full shadow-sm">
                        <header className="bg-white border-b-4 border-primary p-4 flex items-center justify-between">
                            <div className="flex items-center gap-3">
                                <button onClick={() => setCurrentScreen(0)} className="w-12 h-12 rounded-full flex items-center justify-center text-xl bg-blue-50 text-secondary"><i className="fa-solid fa-house"></i></button>
                                <i className="fa-solid fa-earth-americas text-3xl text-primary hidden md:block"></i>
                                <h1 className="text-xl font-medium text-secondary hidden md:block">{formatText(CONTENT.title, 'none')}</h1>
                            </div>
                            <div className="flex items-center gap-4">
                                <div className="bg-blue-50 rounded-lg p-1 border border-accent flex text-sm font-medium">
                                    <button onClick={() => setNikkudLevel('full')} className={`px-3 py-1.5 rounded ${nikkudLevel === 'full' ? 'bg-secondary text-white' : 'text-secondary'}`}>מלא</button>
                                    <button onClick={() => setNikkudLevel('partial')} className={`px-3 py-1.5 rounded ${nikkudLevel === 'partial' ? 'bg-secondary text-white' : 'text-secondary'}`}>חלקי</button>
                                    <button onClick={() => setNikkudLevel('none')} className={`px-3 py-1.5 rounded ${nikkudLevel === 'none' ? 'bg-secondary text-white' : 'text-secondary'}`}>ללא</button>
                                </div>
                                <button onClick={() => { const nm = !isMuted; setIsMuted(nm); if (!nm) { initNoise(); if (audioCtxRef.current && audioCtxRef.current.state === 'suspended') audioCtxRef.current.resume(); } else { if (audioCtxRef.current && audioCtxRef.current.state === 'running') audioCtxRef.current.suspend(); } }} className={`w-12 h-12 rounded-full flex items-center justify-center text-xl shadow-md ${isMuted ? 'bg-gray-200 text-gray-600' : 'bg-secondary text-white'}`}><i className={`fa-solid ${isMuted ? 'fa-volume-xmark' : 'fa-wave-square'}`}></i></button>
                            </div>
                        </header>
                        <nav className="bg-white border-b-2 border-accent overflow-x-auto whitespace-nowrap px-4 py-3 flex gap-3 hide-scrollbar shadow-inner w-full" dir="rtl">
                            {screenTitles.map((title, i) => (
                                <button key={i} onClick={() => { setCurrentScreen(i); window.scrollTo({ top: 0, behavior: 'smooth' }); }} className={`px-5 py-2 rounded-full text-sm md:text-base font-medium transition-all ${currentScreen === i ? 'bg-secondary text-white scale-105 border-2 border-secondary' : 'bg-blue-50 text-secondary border-2 border-accent'}`}>{title}</button>
                            ))}
                        </nav>
                        <div className="w-full bg-accent h-3 border-b border-blue-200"><div className="bg-primary h-full transition-all duration-500 ease-out" style={{ width: `${(currentScreen / (screens.length - 1)) * 100}%` }}></div></div>
                    </div>
                    <main className="flex-1 relative max-w-6xl mx-auto w-full p-4 md:p-6 pb-20">{screens[currentScreen]}</main>
                    {currentScreen > 0 && (
                        <footer className="bg-white border-t flex flex-col z-40 sticky bottom-0 shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.1)] mt-auto w-full">
                            <div className="p-4 flex justify-between items-center w-full">
                                <button onClick={() => { setCurrentScreen(Math.max(0, currentScreen - 1)); window.scrollTo({ top: 0, behavior: 'smooth' }); }} disabled={currentScreen === 0} className="px-6 py-2 bg-blue-50 text-secondary font-medium rounded-lg disabled:opacity-50 border border-accent"><i className="fa-solid fa-arrow-right mr-2"></i> הקודם</button>
                                <button onClick={() => { setCurrentScreen(Math.min(screens.length - 1, currentScreen + 1)); window.scrollTo({ top: 0, behavior: 'smooth' }); }} disabled={currentScreen === screens.length - 1} className="px-6 py-2 bg-secondary text-white rounded-lg disabled:opacity-50 font-medium">הבא <i className="fa-solid fa-arrow-left ml-2"></i></button>
                            </div>
                            <div className="bg-blue-50 text-center py-2 text-xs md:text-sm font-normal text-secondary border-t border-accent w-full shadow-inner"><i className="fa-solid fa-star text-primary text-[10px] mr-1"></i> נוצר ע"י מורן קמיל גלברג הוראה מוּתְאֶמֶת, באמצעות בינה מלאכותית <i className="fa-solid fa-star text-primary text-[10px] ml-1"></i></div>
                        </footer>
                    )}
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
